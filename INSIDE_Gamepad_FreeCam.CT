    <CheatEntry>
      <ID>12</ID>
      <Description>"Gamepad toggle listener: LB=FreeCam, RB=Pause (keep enabled)"</Description>
      <LastState Activated="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript><![CDATA[[ENABLE]
{$lua}
if syntaxcheck then return end
-- Hide CE Lua engine so its window doesn't pop to foreground on print().
pcall(function()
  if type(getLuaEngine) == 'function' then
    local le = getLuaEngine()
    if le and le.hide then le.hide() end
  end
end)

-- Always-active background poller: edge-triggers LB and RB to toggle the
-- FreeCam and Time Pause entries respectively. Works independently of
-- FreeCam being active, giving full gamepad parity with F1 / tilde keys.
local t = createTimer(getMainForm())
t.Interval = 50
t.OnTimer = function()
  local gp = getXBox360ControllerState(0)
  if not gp then return end

  -- LB = toggle FreeCam entry
  local lb = gp.GAMEPAD_LEFT_SHOULDER
  if lb and not _G['INSIDE_LBGLOBAL_PREV'] then
    pcall(function()
      local al = getAddressList()
      if al then
        local mr = al.getMemoryRecordByDescription('ENABLE FreeCam (toggle: F1 / LB)')
        if mr then
          mr.Active = not mr.Active
          print(string.format('[LB] FreeCam toggled -> %s', tostring(mr.Active)))
        end
      end
    end)
  end
  _G['INSIDE_LBGLOBAL_PREV'] = lb

  -- RB = toggle Time Pause entry
  local rb = gp.GAMEPAD_RIGHT_SHOULDER
  if rb and not _G['INSIDE_RBGLOBAL_PREV'] then
    pcall(function()
      local al = getAddressList()
      if al then
        local mr = al.getMemoryRecordByDescription('Toggle Time Pause (toggle: `~ / RB)')
        if mr then
          mr.Active = not mr.Active
          print(string.format('[RB] Time Pause toggled -> %s', tostring(mr.Active)))
        end
      end
    end)
  end
  _G['INSIDE_RBGLOBAL_PREV'] = rb
end
_G['INSIDE_GPLISTEN_TIMER'] = t
print('[Gamepad Listener] running (LB=FreeCam, RB=Pause)')

[DISABLE]
{$lua}
if syntaxcheck then return end
local t = _G['INSIDE_GPLISTEN_TIMER']
if t then pcall(function() t.destroy() end); _G['INSIDE_GPLISTEN_TIMER'] = nil end
_G['INSIDE_LBGLOBAL_PREV'] = nil
_G['INSIDE_RBGLOBAL_PREV'] = nil
print('[Gamepad Listener] stopped')
]]></AssemblerScript>
    </CheatEntry>

